{
  "functions": {
    "api/publish.js":      { "maxDuration": 30 },
    "api/upload-thumb.js": { "maxDuration": 30 },
    "api/upload-source.js":{ "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/admin(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy",  "value": "require-corp" }
      ]
    }
  ]
}
